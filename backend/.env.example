# Copie este arquivo para um gerenciador de variaveis do ambiente.
# Nunca preencha valores reais neste arquivo e nunca envie um .env ao GitHub.

PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGDATABASE=licitahub_dev
PGPASSWORD=
APP_PORT=8080
PUBLIC_BASE_URL=http://127.0.0.1:8080
LICITAHUB_LOG_PATH=logs/licitahub.log
LICITAHUB_BOOTSTRAP_ADMIN_PASSWORD=
OPENAI_API_KEY=
OPENAI_TECHNICAL_ANALYSIS_MODEL=gpt-5.6
OPENAI_CAPTURE_CLASSIFICATION_MODEL=gpt-5.6
GEMINI_API_KEY=
GEMINI_TECHNICAL_ANALYSIS_MODEL=gemini-3.5-flash
GEMINI_TENDER_ANALYSIS_MODEL=gemini-3.5-flash
GEMINI_CAPTURE_CLASSIFICATION_MODEL=gemini-3.5-flash
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
GROQ_TECHNICAL_ANALYSIS_MODEL=openai/gpt-oss-20b
GROQ_CAPTURE_CLASSIFICATION_MODEL=openai/gpt-oss-20b
